@echo off
chcp 65001 >nul
title Kimi Monitor Auto-Start Installer

setlocal EnableDelayedExpansion

echo ============================================
echo Kimi Monitor Windows Auto-Start Installer
echo ============================================
echo.

:: Check admin privileges
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo [ERROR] Please run as Administrator!
    pause
    exit /b 1
)

:: Configuration
set "SERVICE_NAME=AgentTrace"
set "DISPLAY_NAME=AgentTrace"
set "PYTHON_PATH={{PYTHON_PATH}}"
set "WORKING_DIR={{WORKING_DIR}}"
set "LOG_DIR={{LOG_DIR}}"
set "ENV_FILE_PATH={{ENV_FILE_PATH}}"

:: Create log directory
if not exist "%LOG_DIR%" mkdir "%LOG_DIR%"

:: Create wrapper script with .env file loading
set "WRAPPER_SCRIPT=%WORKING_DIR%\agent_trace_service.py"
(
echo #!/usr/bin/env python3
echo # Windows Service Wrapper for Kimi Monitor
echo.
echo import sys
echo import os
echo import logging
echo import servicemanager
echo import win32serviceutil
echo import win32service
echo import win32event
echo.
echo # Add project to path
echo sys.path.insert(0, r"%WORKING_DIR%")
echo.
echo # Load environment variables from .env file
echo env_file = r"%ENV_FILE_PATH%"
echo if os.path.exists(env_file):
echo     with open(env_file, 'r', encoding='utf-8') as f:
echo         for line in f:
echo             line = line.strip()
echo             if line and not line.startswith('#') and '=' in line:
echo                 key, value = line.split('=', 1)
echo                 os.environ[key] = value
echo else:
echo     # Fallback: check if env vars are already set
echo     pass
echo.
echo class AgentTraceService(win32serviceutil.ServiceFramework):
echo     _svc_name_ = "AgentTrace"
echo     _svc_display_name_ = "AgentTrace Service"
echo     _svc_description_ = "AI IDE Session Monitor for Coze Compass"
echo.
echo     def __init__(self, args):
echo         win32serviceutil.ServiceFramework.__init__(self, args)
echo         self.stop_event = win32event.CreateEvent(None, 0, 0, None)
echo         self.monitor = None
echo.
echo     def SvcStop(self):
echo         self.ReportServiceStatus(win32service.SERVICE_STOP_PENDING)
echo         win32event.SetEvent(self.stop_event)
echo         if self.monitor:
echo             self.monitor.stop()
echo.
echo     def SvcDoRun(self):
echo         servicemanager.LogMsg(
echo             servicemanager.EVENTLOG_INFORMATION_TYPE,
echo             servicemanager.PYS_SERVICE_STARTED,
echo             (self._svc_name_, "")
echo         )
echo         self.main()
echo.
echo     def main(self):
echo         from agent_trace.core.monitor import KimiSessionMonitor
echo         from agent_trace.utils.config import Config
echo.
echo         config = Config()
echo         self.monitor = KimiSessionMonitor(
echo             sessions_dir=config.sessions_dir,
echo             poll_interval=config.poll_interval,
echo         )
echo         self.monitor.start()
echo.
echo if __name__ == "__main__":
echo     if len(sys.argv) == 1:
echo         servicemanager.Initialize()
echo         servicemanager.PrepareToHostSingle(AgentTraceService)
echo         servicemanager.StartServiceCtrlDispatcher()
echo     else:
echo         win32serviceutil.HandleCommandLine(AgentTraceService)
) > "%WRAPPER_SCRIPT%"

echo [OK] Created service wrapper script
echo.

:: Check if .env file exists and is configured
if not exist "%ENV_FILE_PATH%" (
    echo [ERROR] Environment file not found: %ENV_FILE_PATH%
    echo [INFO] Please create this file with your COZELOOP_API_TOKEN and COZELOOP_WORKSPACE_ID
    pause
    exit /b 1
)

:: Install Python service dependencies
echo Installing dependencies...
"%PYTHON_PATH%" -m pip install pywin32 --quiet
if %errorLevel% neq 0 (
    echo [WARNING] Failed to install pywin32
)

:: Register service
echo Registering service...
"%PYTHON_PATH%" "%WRAPPER_SCRIPT%" --startup auto install
if %errorLevel% neq 0 (
    echo [ERROR] Failed to register service!
    pause
    exit /b 1
)

echo.
echo ============================================
echo [OK] Service installed successfully!
echo.
echo Service Name: %SERVICE_NAME%
echo Display Name: %DISPLAY_NAME%
echo.
echo Commands:
echo   net start %SERVICE_NAME%    - Start service
echo   net stop %SERVICE_NAME%     - Stop service
echo   sc delete %SERVICE_NAME%    - Uninstall service
echo.
echo Starting service...
net start %SERVICE_NAME%
echo.
pause
